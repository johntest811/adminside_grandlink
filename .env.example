# Admin app environment variables (example)
# Copy to .env.local (local) or set in Vercel Project Settings.

# Supabase
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URLs
NEXT_PUBLIC_USER_WEBSITE_URL=
NEXT_PUBLIC_BASE_URL=

# Gmail SMTP (Primary sender)
GMAIL_USER=
GMAIL_PASS=
GMAIL_FROM=

# Optional: Backup Gmail sender (auto-failover)
GMAIL_BACKUP_USER=
GMAIL_BACKUP_PASS=
GMAIL_BACKUP_FROM=
